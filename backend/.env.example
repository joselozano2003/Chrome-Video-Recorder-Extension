# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Redis (Docker Compose default) ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Google API ─────────────────────────────────────────────────────────────────
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Drive API, Google Docs API
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Service account JSON key (alternative to OAuth — useful for backend-only calls)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# ── AssemblyAI ─────────────────────────────────────────────────────────────────
# Get your key at: assemblyai.com → Dashboard → API Key
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# ── SendGrid ───────────────────────────────────────────────────────────────────
# Create at: sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=noreply@yourdomain.com
